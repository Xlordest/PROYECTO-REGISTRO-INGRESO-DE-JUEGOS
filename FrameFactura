    private void button1ActionPerformed(java.awt.event.ActionEvent evt) {                                        

        double precioTiempo= Double.parseDouble(txtPrecioHora.getText());
        String tiempoJugado= cbHora.getSelectedItem().toString();
        int cantNinos= Integer.parseInt(txtNinos.getText());
        double tiempoJuego;
        tiempoJuego = switch (tiempoJugado) {
            case "1 hora" -> 1;
            case "30 minutos" -> 0.5;
            default -> 3;
        };
        Factura factura;
        factura= new Factura(tiempoJuego, tiempoJugado, precioTiempo, cantNinos);
        if (factura.validarFactura()) {
            double subtotal= factura.calcularSubTotal();
            double total= factura.calcularTotal();
            txtSubtotal.setText(subtotal + " ");
            txtDescuento.setText(String.format("%.2f", factura.calcularDescuento()));
            txtIVA.setText(String.format("%.2f", factura.calcularIVA()));
            txtTotal.setText(String.format("%.2f", total));
        }else{
            JOptionPane.showMessageDialog(this, "ERROR AL GENERAR LA FACTURA..");
        }
    }                                       

    private void btnLimpiarActionPerformed(java.awt.event.ActionEvent evt) {                                           
